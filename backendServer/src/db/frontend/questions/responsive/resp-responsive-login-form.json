    "referenceSolution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Login Form</title>\n    <link rel=\"stylesheet\" href=\"styles.css\">\n</head>\n<body class=\"flex justify-center items-center h-screen\">\n    <div class=\"bg-gray-100 w-full max-w-md p-8 shadow-md rounded-lg\">\n        <h2 class=\"text-2xl text-gray-600 font-bold mb-4\">Login</h2>\n        <form class=\"space-y-4\">\n            <div class=\"flex flex-col space-y-2\">\n                <label for=\"username\" class=\"block text-sm font-medium text-gray-700\">Username</label>\n                <input type=\"text\" id=\"username\" name=\"username\" class=\"block w-full px-4 py-2 text-sm font-medium text-gray-700 bg-white border-gray-300 rounded-md focus:outline-none focus:border-indigo-500\" placeholder=\"Username\">\n            </div>\n            <div class=\"flex flex-col space-y-2\">\n                <label for=\"password\" class=\"block text-sm font-medium text-gray-700\">Password</label>\n                <input type=\"password\" id=\"password\" name=\"password\" class=\"block w-full px-4 py-2 text-sm font-medium text-gray-700 bg-white border-gray-300 rounded-md focus:outline-none focus:border-indigo-500\" placeholder=\"Password\">\n            </div>\n            <button type=\"submit\" class=\"w-full px-4 py-2 text-sm font-medium text-white bg-indigo-600 border border-transparent rounded-md focus:outline-none focus:border-indigo-500 hover:bg-indigo-700\">Login</button>\n        </form>\n    </div>\n</body>\n</html>\n\n<style>\n    @import \"tailwindcss/base\";\n    @import \"tailwindcss/components\";\n    @import \"tailwindcss/utilities\";\n    .container {\n        max-width: 500px;\n        margin: 40px auto;\n        padding: 20px;\n        background-color: #f9f9f9;\n        border: 1px solid #ccc;\n        border-radius: 10px;\n        box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n    }\n</style>"
  },
