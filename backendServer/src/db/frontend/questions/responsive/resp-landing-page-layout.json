    "referenceSolution": "<!-- Index.html -->\n<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Landing Page</title>\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/tailwindcss/2.2.19/tailwind.css\">\n</head>\n<body>\n    <!-- Header section -->\n    <header class=\"bg-gray-800 py-4 text-gray-100\">\n        <div class=\"container mx-auto px-4 flex justify-between items-center\">\n            <a href=\"\" class=\"text-lg font-bold\">Logo</a>\n            <nav class=\"flex items-center space-x-4\">\n                <a href=\"\" class=\"text-gray-400 hover:text-gray-100\">Home</a>\n                <a href=\"\" class=\"text-gray-400 hover:text-gray-100\">About</a>\n                <a href=\"\" class=\"text-gray-400 hover:text-gray-100\">Contact</a>\n            </nav>\n        </div>\n    </header>\n    <!-- Hero section -->\n    <section class=\"hero bg-cover bg-center h-screen relative\" style=\"background-image: url('https://picsum.photos/2000/1000')\">\n        <div class=\"container mx-auto px-4 py-20 relative\">\n            <h1 class=\"text-4xl text-white font-bold mb-4\">Hero Heading</h1>\n            <p class=\"text-gray-100\">Hero paragraph</p>\n        </div>\n    </section>\n    <!-- Features section -->\n    <section class=\"features py-20\">\n        <div class=\"container mx-auto px-4 flex flex-wrap justify-center\">\n            <div class=\"w-full md:w-1/3 xl:w-1/3 p-6\">\n                <div class=\"bg-white rounded shadow-md p-8\">\n                    <h2 class=\"text-2xl text-gray-800 font-bold mb-4\">Feature 1</h2>\n                    <p class=\"text-gray-600\">Feature 1 paragraph</p>\n                </div>\n            </div>\n            <div class=\"w-full md:w-1/3 xl:w-1/3 p-6\">\n                <div class=\"bg-white rounded shadow-md p-8\">\n                    <h2 class=\"text-2xl text-gray-800 font-bold mb-4\">Feature 2</h2>\n                    <p class=\"text-gray-600\">Feature 2 paragraph</p>\n                </div>\n            </div>\n            <div class=\"w-full md:w-1/3 xl:w-1/3 p-6\">\n                <div class=\"bg-white rounded shadow-md p-8\">\n                    <h2 class=\"text-2xl text-gray-800 font-bold mb-4\">Feature 3</h2>\n                    <p class=\"text-gray-600\">Feature 3 paragraph</p>\n                </div>\n            </div>\n        </div>\n    </section>\n    <!-- Contact section -->\n    <section class=\"contact py-20\">\n        <div class=\"container mx-auto px-4\">\n            <h2 class=\"text-2xl text-gray-800 font-bold mb-4\">Contact Us</h2>\n            <form class=\"w-full md:w-1/2 xl:w-1/3 p-6\">\n                <input type=\"text\" placeholder=\"Name\" class=\"w-full p-4 mb-4 border border-gray-400\">\n                <input type=\"email\" placeholder=\"Email\" class=\"w-full p-4 mb-4 border border-gray-400\">\n                <textarea placeholder=\"Message\" class=\"w-full p-4 mb-4 border border-gray-400\"></textarea>\n                <button type=\"submit\" class=\"bg-gray-800 text-white font-bold py-2 px-4 rounded\">Submit</button>\n            </form>\n            <div class=\"flex space-x-4 mt-4\">\n                <a href=\"\" class=\"p-4 bg-gray-800 text-white rounded\"><i class=\"fab fa-facebook-f\"></i></a>\n                <a href=\"\" class=\"p-4 bg-gray-800 text-white rounded\"><i class=\"fab fa-twitter\"></i></a>\n                <a href=\"\" class=\"p-4 bg-gray-800 text-white rounded\"><i class=\"fab fa-instagram\"></i></a>\n            </div>\n        </div>\n    </section>\n</body>\n</html>"
