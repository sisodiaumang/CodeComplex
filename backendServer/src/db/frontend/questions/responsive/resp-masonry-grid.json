    "referenceSolution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Masonry Grid</title>\n    <link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css\">\n    <style>\n        .grid-item {\n            transition: transform 0.5s;\n        }\n        .grid-item img {\n            width: 100%;\n            height: 100%;\n            object-fit: cover;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"grid grid-cols-3 gap-4 max-w-3xl mx-auto p-4\">\n        <div class=\"grid-item bg-red-500 h-28 mb-4 relative\">\n            <img src=\"https://picsum.photos/200/300\" alt=\"Image 1\">\n        </div>\n        <div class=\"grid-item bg-blue-500 h-32 mb-4 relative\">\n            <img src=\"https://picsum.photos/220/310\" alt=\"Image 2\">\n        </div>\n        <div class=\"grid-item bg-green-500 h-40 relative\">\n            <img src=\"https://picsum.photos/200/300\" alt=\"Image 3\">\n        </div>\n    </div>\n    <script>\n        const gridItems = document.querySelectorAll('.grid-item');\n        gridItems.forEach(item => {\n            const itemHeight = item.offsetHeight;\n            item.style.height = `${itemHeight}px`;\n        });\n    </script>\n</body>\n</html>"
