    "referenceSolution": "<html>\n<head>\n    <link href='https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css' rel='stylesheet'>\n    <title>Responsive Table</title>\n</head>\n<body>\n    <div class='container mx-auto p-4 sm:p-6 xl:p-12'>\n        <table class='w-full table-auto border-collapse border border-slate-500 text-left'>\n            <thead class='bg-slate-100'>\n                <tr class='text-slate-900'>\n                    <th class='px-4 py-2'>Name</th>\n                    <th class='px-4 py-2'>Age</th>\n                    <th class='px-4 py-2'>Occupation</th>\n                </tr>\n            </thead>\n            <tbody>\n                <tr class='border-b border-slate-200'>\n                    <td class='border-r border-slate-200 px-4 py-2'>John</td>\n                    <td class='border-r border-slate-200 px-4 py-2'>25</td>\n                    <td class='px-4 py-2'>Developer</td>\n                </tr>\n                <tr class='border-b border-slate-200'>\n                    <td class='border-r border-slate-200 px-4 py-2'>Jane</td>\n                    <td class='border-r border-slate-200 px-4 py-2'>31</td>\n                    <td class='px-4 py-2'>Designer</td>\n                </tr>\n                <tr class='border-b border-slate-200'>\n                    <td class='border-r border-slate-200 px-4 py-2'>Bob</td>\n                    <td class='border-r border-slate-200 px-4 py-2'>42</td>\n                    <td class='px-4 py-2'>Manager</td>\n                </tr>\n            </tbody>\n        </table>\n    </div>\n</body>\n</html>"
