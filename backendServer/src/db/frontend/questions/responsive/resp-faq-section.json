    "referenceSolution": "<!-- FAQ Section HTML Starter Code -->\n<div class=\"w-1/2 mx-auto mt-10\">\n    <h2 class=\"text-lg font-bold mb-4\">Frequently Asked Questions</h2>\n    <!-- FAQ Items Container -->\n    <div class=\"max-h-0 overflow-hidden transition-all duration-500\">\n        <!-- FAQ Item 1 -->\n        <button class=\"bg-gray-200 p-2 mb-2 rounded-lg\" type=\"button\" data-collapse-toggle=\"faq-1\" aria-controls=\"faq-1\" aria-expanded=\"false\">\n            FAQ 1\n        </button>\n        <div class=\"bg-gray-100 p-4 mb-4 border border-gray-200 rounded-lg\" id=\"faq-1\" data-collapse=\"faq-1\">\n            <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed sit amet nulla auctor, vestibulum magna sed, convallis ex.</p>\n        </div>\n        <!-- FAQ Item 2 -->\n        <button class=\"bg-gray-200 p-2 mb-2 rounded-lg\" type=\"button\" data-collapse-toggle=\"faq-2\" aria-controls=\"faq-2\" aria-expanded=\"false\">\n            FAQ 2\n        </button>\n        <div class=\"bg-gray-100 p-4 mb-4 border border-gray-200 rounded-lg\" id=\"faq-2\" data-collapse=\"faq-2\">\n            <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed sit amet nulla auctor, vestibulum magna sed, convallis ex.</p>\n        </div>\n    </div>\n</div>\n\n<script>\n    // Initialize collapse plugin\n    const collapse = document.querySelectorAll('.collapse');\n    const toggleButton = document.querySelectorAll('button[data-collapse]');\n\n    collapse.forEach((collapseElement) => {\n        toggleButton.forEach((toggleElement) => {\n            if (toggleElement.getAttribute('data-collapse') === collapseElement.getAttribute('id')) {\n                toggleElement.addEventListener('click', () => {\n                    collapseElement.classList.toggle('show');\n                    document.querySelector('.max-h-0').classList.toggle('max-h-screen');\n                });\n            }\n        });\n    });\n</script>"
  },
