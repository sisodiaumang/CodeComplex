    "referenceSolution": "<!DOCTYPE html>\n<html>\n  <head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Team Member Grid</title>\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/tailwindcss/2.2.19/tailwind.min.css\">\n  </head>\n  <body>\n    <div class=\"container mx-auto p-4\">\n      <div class=\"grid grid-cols-3 gap-4\">\n        <!-- Team Member Card -->\n        <div class=\"w-full p-4 shadow-md rounded-lg hover:shadow-lg hover:bg-gray-100\">\n          <img src=\"https://picsum.photos/200\" class=\"w-16 h-16 rounded-full mb-4\" alt=\"Profile Picture\">\n          <h2 class=\"text-lg font-bold mb-2\">John Doe</h2>\n          <p class=\"text-sm text-gray-600 mb-4\">Software Engineer</p>\n          <button class=\"bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded\">View Profile</button>\n        </div>\n        <!-- Team Member Card -->\n        <div class=\"w-full p-4 shadow-md rounded-lg hover:shadow-lg hover:bg-gray-100\">\n          <img src=\"https://picsum.photos/200\" class=\"w-16 h-16 rounded-full mb-4\" alt=\"Profile Picture\">\n          <h2 class=\"text-lg font-bold mb-2\">Jane Doe</h2>\n          <p class=\"text-sm text-gray-600 mb-4\">UX Designer</p>\n          <button class=\"bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded\">View Profile</button>\n        </div>\n        <!-- Team Member Card -->\n        <div class=\"w-full p-4 shadow-md rounded-lg hover:shadow-lg hover:bg-gray-100\">\n          <img src=\"https://picsum.photos/200\" class=\"w-16 h-16 rounded-full mb-4\" alt=\"Profile Picture\">\n          <h2 class=\"text-lg font-bold mb-2\">Bob Smith</h2>\n          <p class=\"text-sm text-gray-600 mb-4\">Product Manager</p>\n          <button class=\"bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded\">View Profile</button>\n        </div>\n      </div>\n    </div>\n  </body>\n</html>