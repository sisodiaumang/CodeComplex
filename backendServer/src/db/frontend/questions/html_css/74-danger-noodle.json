    "referenceSolution": "<div id=\"a\"></div>\n<div></div>\n<div></div>\n<div></div>\n<div id=\"e\"></div>\n<div id=\"f\"></div>\n<p></p>\n<style>\n  body {\n    background: #191919;\n    display: flex;\n    align-items: center;\n    gap: 30px;\n    margin: 0px;\n  }\n  div {\n    width: 10px;\n    height: 150px;\n    background: #191919;\n    border: 5px solid #E08027;\n    border-top: 0px;\n    border-bottom: 0px;\n  }\n  #a {\n    margin-left: 15px;\n    translate: 0px -50px;\n  }\n  #a, #e {\n    height: 50px;\n  }\n  #e {\n    translate: 0px 50px;\n  }\n  #f {\n    rotate: 90deg;\n    height: 20px;\n    translate: -20px;\n  }\n  div:before {\n    content: \"\";\n    display: block;\n    width: 70px;\n    height: 70px;\n    background: #191919;\n    border-radius: 50%;\n    box-shadow: inset 0 0 0 5px #E08027,\n      inset 0 0 0 15px #191919, inset 0 0 0 20px #E08027;\n    clip-path: polygon(0% 0%, 100% 0%, 100% 50%, 0% 50%);\n    translate: -5px -35px;\n  }\n  div:nth-of-type(even):before {\n    rotate: 180deg;\n    translate: -5px 115px;\n  }\n  #e:before {\n    clip-path: polygon(0 0, 50% 0, 50% 50%, 0 50%);\n  }\n  #f:before {\n    translate: -55px 230px;\n    rotate: 90deg;\n  }\n  p {\n    background: #E08027;\n    height: 30px;\n    width: 50px;\n    border-radius: 15px 20px 20px 15px;\n    translate: -50px;\n    display: grid;\n    align-content: center;\n    gap: 5px;\n  }\n  p:before, p:after {\n    display: block;\n    content: \"\";\n    border-radius: 50%;\n    background: #191919;\n    width: 10px;\n    height: 10px;\n    margin-left: 30px;\n  }\n</style>"
