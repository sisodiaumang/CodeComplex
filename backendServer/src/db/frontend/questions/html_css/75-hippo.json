    "referenceSolution": "<div id=\"ear1\"></div>\n<div id=\"ear2\"></div>\n<div id=\"head\"></div>\n<div id=\"nose\"></div>\n<style>\n  body {\n    background: #191919;\n    display: grid;\n    place-content: center;\n    place-items: center;\n    grid-template: 40px 50px 80px / 80px 80px;\n  }\n  #ear1, #ear2 {\n    width: 20px;\n    height: 10px;\n    background: #000000;\n    border-radius: 50%;\n    border: 5px solid #FE5F55;\n    rotate: 45deg;\n    z-index: -1;\n  }\n  #ear2 {\n    rotate: -45deg;\n  }\n  #head {\n    width: 130px;\n    height: 110px;\n    background: #FE5F55;\n    border-radius: 60px 60px 0px 0px;\n    padding: 25px;\n  }\n  #nose {\n    width: 150px;\n    height: 100px;\n    background: #A64942;\n    border-radius: 120px 120px 100px 100px;\n    padding: 20px;\n  }\n  #head, #nose {\n    grid-column: span 2;\n    box-sizing: border-box;\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n  }\n  div:before, div:after {\n    content: \"\";\n    display: block;\n    background: #000000;\n    border-radius: 50%;\n  }\n  #head:before, #head:after {\n    width: 10px;\n    height: 10px;\n  }\n  #nose:before, #nose:after {\n    width: 30px;\n    height: 20px;\n    rotate: -45deg;\n    margin-bottom: 30px;\n  }\n  #nose:after {\n    rotate: 45deg;\n  }\n</style>"
