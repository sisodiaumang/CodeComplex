    "referenceSolution": "<div id=\"hat\"></div>\n<div id=\"brim\"></div>\n<div id=\"head\"></div>\n<div id=\"scarf\"></div>\n<div id=\"body\"></div>\n<style>\n  body {\n    background: #AC474B;\n    display: grid;\n    place-content: center;\n    place-items: center;\n  }\n  #hat {\n    width: 40px;\n    height: 40px;\n    background: linear-gradient(#0E1F2B 15px, #FFFFFF 15px 25px, #0E1F2B 25px);\n    translate: 0px 16px;\n  }\n  #brim {\n    width: 60px;\n    height: 5px;\n    background: #0E1F2B;\n    translate: 0px 16px;\n  }\n  #head {\n    width: 60px;\n    height: 60px;\n    background: #FFFFFF;\n    border-radius: 50%;\n    translate: 0px 11px;\n    z-index: -1;\n  }\n  #scarf {\n    height: 10px;\n    width: 60px;\n    background: #FFA63F;\n    border-radius: 10px;\n    border: 4px solid #AC474B;\n    translate: 0px -5px;\n    z-index: 1;\n  }\n  #body {\n    width: 100px;\n    height: 100px;\n    border-radius: 50%;\n    background: linear-gradient(#AC474B 12px, #FFFFFF 12px);\n    translate: 0px -17px;\n  }\n  #brim:before {\n    content: \"\";\n    display: block;\n    width: 10px;\n    height: 10px;\n    background: #0E1F2B;\n    border-radius: 50%;\n    translate: 15px 18px;\n    box-shadow: 20px 0px #0E1F2B;\n  }\n</style>"
