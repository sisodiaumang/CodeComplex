    "referenceSolution": "<!-- index.html -->\n<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Accessible Grid Navigation</title>\n    <link rel=\"stylesheet\" href=\"https://cdn.tailwindcss.com\">\n</head>\n<body>\n    <div class=\"grid grid-cols-3 grid-rows-3 gap-4 mx-auto p-4\" aria-label=\"Grid Navigation\" role=\"tablist\">\n        <div class=\"bg-gray-200 p-4 cursor-pointer\" tabindex=\"0\" role=\"tab\" aria-selected=\"true\">Item 1</div>\n        <div class=\"bg-gray-200 p-4 cursor-pointer\" tabindex=\"0\" role=\"tab\">Item 2</div>\n        <div class=\"bg-gray-200 p-4 cursor-pointer\" tabindex=\"0\" role=\"tab\">Item 3</div>\n        <div class=\"bg-gray-200 p-4 cursor-pointer\" tabindex=\"0\" role=\"tab\">Item 4</div>\n        <div class=\"bg-gray-200 p-4 cursor-pointer\" tabindex=\"0\" role=\"tab\">Item 5</div>\n        <div class=\"bg-gray-200 p-4 cursor-pointer\" tabindex=\"0\" role=\"tab\">Item 6</div>\n        <div class=\"bg-gray-200 p-4 cursor-pointer\" tabindex=\"0\" role=\"tab\">Item 7</div>\n        <div class=\"bg-gray-200 p-4 cursor-pointer\" tabindex=\"0\" role=\"tab\">Item 8</div>\n        <div class=\"bg-gray-200 p-4 cursor-pointer\" tabindex=\"0\" role=\"tab\">Item 9</div>\n    </div>\n\n    <script src=\"script.js\"></script>\n</body>\n</html>\n\n<!-- script.js -->\n<script>\n    const gridItems = document.querySelectorAll('.grid div[tabindex]');\n\n    gridItems.forEach((item, index) => {\n        item.addEventListener('keydown', (event) => {\n            if (event.key === 'ArrowUp') {\n                if (index > 0) {\n                    gridItems[index - 1].focus();\n                }\n            } else if (event.key === 'ArrowDown') {\n                if (index < gridItems.length - 1) {\n                    gridItems[index + 1].focus();\n                }\n            } else if (event.key === 'ArrowLeft') {\n                if (index % 3 !== 0) {\n                    gridItems[index - 1].focus();\n                }\n            } else if (event.key === 'ArrowRight') {\n                if (index % 3 !== 2) {\n                    gridItems[index + 1].focus();\n                }\n            }\n        });\n    });\n</script>"
  },
