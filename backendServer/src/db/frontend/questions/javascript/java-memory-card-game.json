    "referenceSolution": "html: <!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Memory Card Game</title>\n    <link rel=\"stylesheet\" href=\"styles.css\">\n</head>\n<body>\n    <div class=\"max-w-md m-auto mt-10\">\n        <div class=\"text-lg font-bold text-center\">Memory Card Game</div>\n        <div class=\"grid grid-cols-4 gap-4 mt-10\">\n            <!-- Card grid will be generated here -->\n            <div class='bg-gray-200 h-32 w-32 mx-2 my-2 shadow-md' id='card-1' onclick=\"flipCard(this)\">\n                <div class='h-full w-full flex items-center justify-center'>\n                    <span class='text-2xl font-bold' id='card-1-value'>-</span>\n                </div>\n            </div>\n            <div class='bg-gray-200 h-32 w-32 mx-2 my-2 shadow-md' id='card-2' onclick=\"flipCard(this)\">\n                <div class='h-full w-full flex items-center justify-center'>\n                    <span class='text-2xl font-bold' id='card-2-value'>-</span>\n                </div>\n            </div>\n            <!-- 12 more cards... -->\n        </div>\n        <div class=\"text-lg font-bold text-center mt-10\">Pairs found: 0</div>\n        <button id=\"play-again\" class=\"mt-10 bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded\">\n            Play Again\n        </button>\n    </div>\n    <script src=\"script.js\"></script>\n</body>\n</html>\njavascript: null"
