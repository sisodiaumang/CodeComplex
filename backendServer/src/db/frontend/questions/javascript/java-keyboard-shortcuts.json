  "statement": {
    "markdown": "title: ## Keyboard Shortcuts\ndescription: Create a keyboard shortcuts application that helps users quickly save and access frequently used keys.\nrequirements\n1. Display a list of saved keys and their corresponding shortcuts.\n2. Allow users to add new keys and shortcuts by typing in a prompt.\n3. Allow users to delete keys and shortcuts from the list.\n4. Store the keys and shortcuts in local storage for persistence across page reloads."
  },
  "constraints": [
    "You may not use any external libraries or frameworks.",
    "You must use local storage to store the keys and shortcuts.",
    "Your application must work in modern browsers (latest 2 versions of Chrome, Firefox, and Safari)."
  ],
  "referenceAssets": [],
  "starterCode": {
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Keyboard Shortcuts</title>\n    <link href=\"https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css\" rel=\"stylesheet\">\n</head>\n<body class=\"bg-gray-100\">\n    <div class=\"max-w-md mx-auto p-4 bg-white rounded shadow-md mt-4\">\n        <h1 class=\"text-lg font-bold mb-2\">Keyboard Shortcuts</h1>\n        <div id=\"keys-list\" class=\"mb-4\"></div>\n        <input id=\"new-key\" type=\"text\" placeholder=\"New key\" class=\"w-1/2 p-2 mb-2 rounded\"/>\n        <input id=\"new-shortcut\" type=\"text\" placeholder=\"New shortcut\" class=\"w-1/2 p-2 mb-2 rounded\"/>\n        <button id=\"add-btn\" class=\"bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded\">Add</button>\n        <button id=\"delete-btn\" class=\"bg-red-500 hover:bg-red-700 text-white font-bold py-2 px-4 rounded\">Delete</button>\n    </div>\n    <script src=\"script.js\"></script>\n</body>\n</html>",
