  "statement": "Implement a simple RESTful API to store and retrieve books. The API should support creating new books, listing all books, and retrieving a book by its ID.\n\n**Endpoints to implement:**\n\n### Create a new book\n\n* `POST /api/books` - Create a new book with the provided title and author.\n  * Payload: `{ title: string, author: string }`",
  "constraints": [
    "Must use the in-memory array provided as the database.",
    "Must handle cases where creating a book with an existing ID fails.",
    "Must handle cases where retrieving a non-existent book fails."
  ],
  "endpoints": [
    {
      "method": "POST",
      "path": "/api/books",
      "description": "Create a new book with the provided title and author."
    },
    {
      "method": "GET",
      "path": "/api/books",
      "description": "List all books."
    },
    {
      "method": "GET",
      "path": "/api/books/:id",
      "description": "Retrieve a book by its ID."
    }
  ],
  "mode": "solve",
  "starterCode": {
    "package.json": "{\n  \"name\": \"book-store\",\n  \"version\": \"1.0.0\",\n  \"main\": \"index.js\",\n  \"scripts\": {\n    \"start\": \"node index.js\"\n  },\n  \"dependencies\": {\n    \"express\": \"^4.18.2\"\n  }\n}",
    "index.js": "const express = require('express');\nconst app = express();\napp.use(express.json());\n\nconst books = [\n  // Add some example books here\n];\n\n// TODO: Implement endpoint to create a new book\n// TODO: Implement endpoint to list all books\n// TODO: Implement endpoint to retrieve a book by its ID\n\nconst PORT = process.env.PORT || 3000;\napp.listen(PORT, () => console.log('Server running on port ' + PORT));"
  },
