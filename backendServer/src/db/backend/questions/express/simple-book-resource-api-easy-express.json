      "path": "/api/books",
      "description": "Create a new book with title and author. Request body must contain 'title' and 'author' fields. Successful response includes the created book with an 'id' property."
    },
    {
      "method": "GET",
      "path": "/api/books",
      "description": "Retrieve a list of all books. Successful response includes a list of books with 'id', 'title', and 'author' properties."
