  "solutions": {
    "python": "# Solution",
    "class Solution:\n   def search(self, nums: List[int], target: int) -> List[int]:\n       def partition(low, high):\n           if low > high:\n               return -1\n           mid = partition(low, high)\n           while mid >= low && nums[mid] >= target:\n               mid -= 1\n           while mid + 1 <= high && nums[mid + 1] <= target:\n               mid += 1\n           return mid\n       def find_first(nums, target):\n           idx = partition(0, len(nums) - 1)\n           if idx == -1 or nums[idx] != target:\n               return -1\n           while idx > 0 and nums[idx - 1] == target:\n               idx -= 1\n           return idx\n       def find_last(nums, target):\n           idx = partition(0, len(nums) - 1)\n           if idx == -1 or nums[idx] != target:\n               return -1\n           while idx < len(nums) - 1 and nums[idx] == target:\n               idx += 1\n           return idx\n       return [find_first(nums, target), find_last(nums, target)]\n       ": "",
    "cpp": "// Solution",
    "class Solution {\n   public:\n   vector<int> search(vector<int>& nums, int target) {\n       int pivot = partition(0, nums.size() - 1);\n       if (pivot == -1 || nums[pivot] != target) {\n           return {-1, -1};\n       }\n       int first = find_first(nums, target, pivot);\n       int last = find_last(nums, target, pivot);\n       return {first, last};\n   }\n\n   int partition(int low, int high) {\n       if (low > high) {\n           return -1;\n       }\n       int mid = low + (high - low) / 2;\n       while (mid >= low && nums[mid] >= target) {\n           mid--;\n       }\n       while (mid + 1 <= high && nums[mid + 1] <= target) {\n           mid++;\n       }\n       return mid;\n   }\n\n   int find_first(vector<int>& nums, int target, int pivot) {\n       int idx = partition(0, pivot - 1);\n       if (idx == -1 || nums[idx] != target) {\n           return -1;\n       }\n       while (idx > 0 && nums[idx - 1] == target) {\n           idx--;\n       }\n       return idx;\n   }\n\n   int find_last(vector<int>& nums, int target, int pivot) {\n       int idx = partition(pivot + 1, nums.size() - 1);\n       if (idx == -1 || nums[idx] != target) {\n           return -1;\n       }\n       while (idx < nums.size() - 1 && nums[idx] == target) {\n           idx++;\n       }\n       return idx;\n   }\n};": "",
