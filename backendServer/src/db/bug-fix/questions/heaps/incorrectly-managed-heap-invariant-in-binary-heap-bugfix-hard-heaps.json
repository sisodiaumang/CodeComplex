  "solutions": {
    "python": "# Solution",
    "\n      class Solution:\n         def heapify(self, arr, n):\n            for i in range(n // 2 - 1, -1, -1):\n               self.sift_down(arr, i, n)\n            return arr\n\n         def sift_down(self, arr, i, n):\n            while 2 * i + 1 < n:\n               min_idx = 2 * i + 1\n               if 2 * i + 2 < n and arr[2 * i + 2] < arr[min_idx]:\n                  min_idx = 2 * i + 2\n               if arr[i] < arr[min_idx]:\n                  break\n               arr[i], arr[min_idx] = arr[min_idx], arr[i]\n               i = min_idx\n\n      arr = [5, 3, 8, 4, 1, 2, 6]\n      n = len(arr)\n      print(Solution().heapify(arr, n))\n      ": "",
    "cpp": "// Solution",
    "\n      #include <iostream>\n\n      class Solution {\n      public:\n         void heapify(int arr[], int n) {\n            for (int i = n / 2 - 1; i >= 0; i--) {\n               sift_down(arr, i, n);\n            }\n         }\n\n         void sift_down(int arr[], int i, int n) {\n            while (2 * i + 1 < n) {\n               int min_idx = 2 * i + 1;\n               if (2 * i + 2 < n && arr[2 * i + 2] < arr[min_idx]) {\n                  min_idx = 2 * i + 2;\n               }\n               if (arr[i] < arr[min_idx]) {\n                  break;\n               }\n               arr[i] = arr[min_idx];\n               arr[min_idx] = arr[i];\n               i = min_idx;\n            }\n         }\n      };\n\n      int main() {\n         int arr[] = {5, 3, 8, 4, 1, 2, 6};\n         int n = sizeof(arr) / sizeof(arr[0]);\n         Solution().heapify(arr, n);\n         return 0;\n      }\n      ": "",
