    "\n         #include <iostream>\n         #include <deque>\n\n         using namespace std;\n         class Solution {\n         public:\n            void remove_front_min(deque<int>& array) {\n               array.pop_front();\n            }\n            void remove_rear_max(deque<int>& array) {\n               array.pop_back();\n               int max_element = array.back();\n               array.pop_back();\n               while (!array.empty() && array.back() != max_element) {\n                  array.pop_back();\n               }\n            }\n         };\n         int main() {\n            Solution s;\n            deque<int> array;\n            int n;\n            cin >> n;\n            for (int i = 0; i < n; i++) {\n               int num;\n               cin >> num;\n               array.push_back(num);\n            }\n            s.remove_front_min(array);\n            while (!array.empty()) {\n               cout << array.front() << ": ";\n               array.pop_front();\n            }\n            cout << endl;\n            s.remove_rear_max(array);\n            while (!array.empty()) {\n               cout << array.front() << ",
