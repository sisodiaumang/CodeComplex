    "python": "class Solution:\n    def closestPerfectSquare(self, n) -> int:\n        sqrt = int(n ** 0.5)\n        return (sqrt + 1) ** 2 if (sqrt + 1) ** 2 <= n else sqrt ** 2\n\nif __name__ == '__main__':\n    s = int(input())\n    for i in range(int(input())):\n        n = int(input())\n        print(Solution().closestPerfectSquare(n))",
