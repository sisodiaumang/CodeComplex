  "solutions": {
    "python": "import sys\nit = iter(sys.stdin.read().split())\nn = int(next(it))\nnums = [int(next(it)) for _ in range(n)]\nresult = 0\nfor i in range(n):\n    max_val = nums[i]\n    min_val = nums[i]\n    for j in range(i, n):\n        max_val = max(max_val, nums[j])\n        min_val = min(min_val, nums[j])\n        result += max_val - min_val\nprint(result)",
    "cpp": "#include <bits/stdc++.h>\nusing namespace std;\nint main(){\n    int n;\n    cin >> n;\n    vector<int> nums(n);\n    for(int i = 0; i < n; i++) cin >> nums[i];\n    long long result = 0;\n    for(int i = 0; i < n; i++){\n        int max_val = nums[i];\n        int min_val = nums[i];\n        for(int j = i; j < n; j++){\n            max_val = max(max_val, nums[j]);\n            min_val = min(min_val, nums[j]);\n            result += max_val - min_val;\n        }\n    }\n    cout << result << endl;\n    return 0;\n}"
