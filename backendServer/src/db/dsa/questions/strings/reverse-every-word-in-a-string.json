  "solutions": {
    "python": "import sys\n\nclass Solution:\n    def reverseWords(self, s: str) -> str:\n        # split by any whitespace, reverse each word, join with single space\n        words = s.split()\n        reversed_words = [w[::-1] for w in words]\n        return ' '.join(reversed_words)\n\nif __name__ == '__main__':\n    data = sys.stdin.read().splitlines()\n    if not data:\n        sys.exit(0)\n    # first line is length (ignored for processing)\n    # second line is the string (may contain spaces)\n    # If there are more lines, concatenate them with newline? Problem states single line string.\n    s = data[1] if len(data) > 1 else ''\n    sol = Solution()\n    ans = sol.reverseWords(s)\n    print(ans)\n",
    "cpp": "#include <bits/stdc++.h>\nusing namespace std;\n\nclass Solution {\npublic:\n    string reverseWords(string s) {\n        vector<string> words;\n        string word;\n        // use stringstream to split by whitespace\n        stringstream ss(s);\n        while (ss >> word) {\n            reverse(word.begin(), word.end());\n            words.push_back(word);\n        }\n        // join with single space\n        string result;\n        for (size_t i = 0; i < words.size(); ++i) {\n            result += words[i];\n            if (i + 1 < words.size()) result += ' ';\n        }\n        return result;\n    }\n};\n\nint main() {\n    ios::sync_with_stdio(false);\n    cin.tie(nullptr);\n    int n;\n    if (!(cin >> n)) return 0;\n    string dummy;\n    getline(cin, dummy); // consume endline after n\n    string s;\n    getline(cin, s);\n    Solution sol;\n    string ans = sol.reverseWords(s);\n    cout << ans << \"\\n\";\n    return 0;\n}\n"
