  "statement": {
    "markdown": "Given an array of integers, find the second largest distinct element in the array. The array contains at least two elements. If multiple elements share the largest value, the second largest is the next distinct smaller value.",
    "inputFormat": "The first line contains an integer n, the number of elements in the array.\nThe second line contains n space-separated integers a1, a2, ..., an.",
    "outputFormat": "Print a single integer — the second largest distinct element of the array.",
    "images": [],
    "constraints": [
      {
        "variable": "n",
        "type": "integer",
        "min": 2,
        "max": 100000,
        "description": "Number of elements in the array"
      },
      {
        "variable": "arr[i]",
        "type": "integer",
        "min": -1000000000,
        "max": 1000000000,
        "description": "Value of each array element"
      }
    ],
    "examples": [
      {
        "input": "5\n2 3 1 5 4",
        "output": "4",
        "explanation": "The largest element is 5 and the second largest distinct element is 4."
      },
      {
        "input": "6\n-1 -5 -3 -2 -4 -6",
        "output": "-2",
        "explanation": "The largest element is -1; the next distinct smaller value is -2, which is the second largest."
      }
    ]
  },
  "hints": [
    {
      "order": 1,
      "text": "Initialize two variables, max and second_max, to the first two elements of the array. Traverse the remaining elements and update max and second_max accordingly."
    },
    {
      "order": 2,
      "text": "Compare each element with max and second_max. If an element is greater than max, update max to that element and reset second_max to max. If an element is smaller than second_max but greater than element_being_checked, update second_max to element_being_checked."
    },
    {
      "order": 3,
      "text": "After traversing the array, if max is not equal to second_max, return max as the second largest element. Otherwise, return second_max as the second largest element."
    }
  ],
  "editorial": {
    "title": "Second Largest Element",
    "intuition": "The problem asks for the second largest element in an array, which can be solved by first removing duplicates and then sorting the array in descending order. The second element in the sorted array will be the second largest.",
    "bruteForce": "A brute force approach would involve comparing each element with every other element to find the maximum and the second maximum, resulting in a time complexity of O(n^2), which is inefficient for large inputs.",
    "betterSolution": "A better approach would be to use a single pass through the array to find the maximum and the second maximum, but this approach is not necessary given the simplicity of the optimal solution.",
    "optimalSolution": "The optimal solution involves removing duplicates by converting the array to a set and then sorting the set in descending order. This approach takes advantage of the built-in sorting functionality in Python, resulting in a time complexity of O(n log n) due to the sorting operation.",
    "proofOfCorrectness": "The correctness of the optimal solution can be proven by the fact that sorting the unique elements in descending order guarantees that the first element is the largest and the second element is the second largest. The use of a set ensures that duplicates are removed, and the sorting operation ensures that the elements are in the correct order.",
    "dryRun": "To verify the correctness of the solution, a dry run can be performed with a sample input array, such as [10, 20, 30, 40, 50], to ensure that the output is indeed the second largest element, which in this case would be 40.",
    "commonMistakes": [
      "Not removing duplicates before sorting",
      "Sorting the array in ascending order instead of descending order",
      "Not handling the case where the input array has less than two unique elements",
      "Using a brute force approach with a time complexity of O(n^2)",
      "Not considering the constraints on the input array, such as the range of values and the number of elements"
    ],
    "timeComplexity": "O(n log n)",
    "spaceComplexity": "O(n)"
  },
