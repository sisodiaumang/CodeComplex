  "solutions": {
    "python": "import sys\nit = iter(sys.stdin.read().split())\nn = int(next(it))\nnums = [int(next(it)) for _ in range(n)]\nunique_nums = sorted(set(nums), reverse=True)\nprint(unique_nums[1])",
    "cpp": "#include <bits/stdc++.h>\nusing namespace std;\nint main(){\n    int n;\n    if(!(cin >> n)) return 0;\n    vector<int> nums(n);\n    for(int i = 0; i < n; i++) cin >> nums[i];\n    set<int> unique_nums(nums.begin(), nums.end());\n    vector<int> sorted_unique_nums(unique_nums.begin(), unique_nums.end());\n    sort(sorted_unique_nums.rbegin(), sorted_unique_nums.rend());\n    cout << sorted_unique_nums[1];\n}"
  },
