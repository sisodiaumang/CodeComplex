  "solutions": {
    "python": "import sys\nit = iter(sys.stdin.read().split())\nN = int(next(it))\nmeetings = [(int(next(it)), int(next(it))) for _ in range(N)]\n# sort by end time, then by start\nmeetings.sort(key=lambda x: (x[1], x[0]))\ncount = 0\nlast_end = -1\nfor s, e in meetings:\n    if s >= last_end:\n        count += 1\n        last_end = e\nprint(count)\n",
    "cpp": "#include <bits/stdc++.h>\nusing namespace std;\nint main(){\n    ios::sync_with_stdio(false);\n    cin.tie(nullptr);\n    int N; if(!(cin>>N)) return 0;\n    vector<pair<long long,long long>> a(N);\n    for(int i=0;i<N;++i){cin>>a[i].first>>a[i].second;}\n    sort(a.begin(), a.end(), [](const auto& p1, const auto& p2){\n        if(p1.second!=p2.second) return p1.second<p2.second;\n        return p1.first<p2.first;\n    });\n    long long last_end = -1; int cnt=0;\n    for(auto &pr: a){\n        if(pr.first>=last_end){\n            ++cnt; last_end=pr.second;\n        }\n    }\n    cout<<cnt;\n    return 0;\n}\n"
  },
