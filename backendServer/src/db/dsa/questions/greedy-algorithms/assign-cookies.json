  "solutions": {
    "python": "import sys\nit = iter(sys.stdin.read().split())\ntry:\n    n = int(next(it))\nexcept StopIteration:\n    sys.exit()\nchildren = [int(next(it)) for _ in range(n)]\nm = int(next(it))\ncookies = [int(next(it)) for _ in range(m)]\nchildren.sort()\ncookies.sort()\ni = j = cnt = 0\nwhile i < n and j < m:\n    if cookies[j] >= children[i]:\n        cnt += 1\n        i += 1\n        j += 1\n    else:\n        j += 1\nprint(cnt)\n",
    "cpp": "#include <bits/stdc++.h>\nusing namespace std;\nint main(){\n    ios::sync_with_stdio(false);\n    cin.tie(nullptr);\n    int n; if(!(cin>>n)) return 0;\n    vector<long long> g(n);\n    for(int i=0;i<n;++i) cin>>g[i];\n    int m; cin>>m;\n    vector<long long> s(m);\n    for(int i=0;i<m;++i) cin>>s[i];\n    sort(g.begin(), g.end());\n    sort(s.begin(), s.end());\n    int i=0,j=0,ans=0;\n    while(i<n && j<m){\n        if(s[j]>=g[i]){ ++ans; ++i; ++j; }\n        else ++j;\n    }\n    cout<<ans;\n    return 0;\n}\n"
  },
