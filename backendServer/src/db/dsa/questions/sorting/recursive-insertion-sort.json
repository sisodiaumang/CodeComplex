  "solutions": {
    "python": "\nimport sys\nit = iter(sys.stdin.read().split())\nn = int(next(it))\nnums = [int(next(it)) for _ in range(n)]\n\ndef recursive_insertion_sort(arr, n):\n    if n <= 1:\n        return\n    recursive_insertion_sort(arr, n-1)\n    key = arr[n-1]\n    j = n-2\n    while j >= 0 and key < arr[j]:\n        arr[j+1] = arr[j]\n        j -= 1\n    arr[j+1] = key\n\nrecursive_insertion_sort(nums, n)\nprint(' '.join(map(str, nums)))\n",
    "cpp": "\n#include <bits/stdc++.h>\nusing namespace std;\nint main(){\n    int n;\n    if(!(cin >> n)) return 0;\n    vector<int> nums(n);\n    for(int i = 0; i < n; i++) cin >> nums[i];\n    function<void(vector<int>&, int)> recursive_insertion_sort = \n        [&](vector<int>& arr, int n) {\n            if (n <= 1) return;\n            recursive_insertion_sort(arr, n-1);\n            int key = arr[n-1];\n            int j = n-2;\n            while (j >= 0 && key < arr[j]) {\n                arr[j+1] = arr[j];\n                j -= 1;\n            }\n            arr[j+1] = key;\n        };\n    recursive_insertion_sort(nums, n);\n    for (int i = 0; i < n; i++) {\n        cout << nums[i] << ' ';\n    }\n    return 0;\n}\n"
  },
