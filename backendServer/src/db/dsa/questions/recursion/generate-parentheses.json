  "solutions": {
    "python": "import sys\n\nclass Solution:\n    def generateParenthesis(self, n: int) -> list[str]:\n        res = []\n        def backtrack(s: str, open: int, close: int):\n            if len(s) == 2 * n:\n                res.append(s)\n                return\n            if open < n:\n                backtrack(s + '(', open + 1, close)\n            if close < open:\n                backtrack(s + ')', open, close + 1)\n        backtrack('', 0, 0)\n        return res\n\nif __name__ == '__main__':\n    data = sys.stdin.read().split()\n    if not data:\n        sys.exit(0)\n    n = int(data[0])\n    sol = Solution()\n    ans = sol.generateParenthesis(n)\n    for line in ans:\n        print(line)",
    "cpp": "#include <bits/stdc++.h>\nusing namespace std;\n\nclass Solution {\npublic:\n    vector<string> generateParenthesis(int n) {\n        vector<string> res;\n        string cur;\n        function<void(int,int)> backtrack = [&](int open, int close) {\n            if ((int)cur.size() == 2 * n) {\n                res.push_back(cur);\n                return;\n            }\n            if (open < n) {\n                cur.push_back('(');\n                backtrack(open + 1, close);\n                cur.pop_back();\n            }\n            if (close < open) {\n                cur.push_back(')');\n                backtrack(open, close + 1);\n                cur.pop_back();\n            }\n        };\n        backtrack(0, 0);\n        return res;\n    }\n};\n\nint main() {\n    ios::sync_with_stdio(false);\n    cin.tie(nullptr);\n    int n;\n    if (!(cin >> n)) return 0;\n    Solution sol;\n    vector<string> ans = sol.generateParenthesis(n);\n    for (const string &s : ans) {\n        cout << s << \"\\n\";\n    }\n    return 0;\n}\n"
  },
