  "statement": {
    "markdown": "Given an array of integers `arr`, a subarray is considered *nice* if the product of its elements is a perfect square. You are allowed to swap elements in the subarray at most once (with an exception that you can swap an element with itself). Return the length of the longest nice subarray.\n\nA perfect square is an integer equal to the square of an integer, i.e., `n == i * i` where `i` is an integer.",
    "inputFormat": "arr",
    "outputFormat": "length",
    "notes": "",
    "images": [],
    "constraints": [
      {
        "variable": "arr",
        "type": "array",
