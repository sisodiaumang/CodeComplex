  "solutions": {
    "python": "import sys\nit = iter(sys.stdin.read().split())\narr = [int(next(it)) for _ in range(int(next(it)))]\ndef prime_factors(n):\n    i = 2\n    factors = {}\n    while i * i <= n:\n        if n % i:\n            i += 1\n        else:\n            n //= i\n            factors[i] = factors.get(i, 0) + 1\n    if n > 1:\n        factors[n] = factors.get(n, 0) + 1\n    return factors\ndef is_perfect_square(n):\n    return all(c % 2 == 0 for c in prime_factors(n).values())\nmax_length = 0\nfor i in range(len(arr)):\n    odd_count = {}\n    for j in range(i, len(arr)):\n        factors = prime_factors(arr[j])\n        for factor, count in factors.items():\n            if count % 2 != 0:\n                odd_count[factor] = odd_count.get(factor, 0) + 1\n        if all(c <= 1 for c in odd_count.values()):\n            max_length = max(max_length, j - i + 1)\nprint(max_length)",
    "cpp": "#include <bits/stdc++.h>\nusing namespace std;\nmap<int, int> prime_factors(int n) {\n    map<int, int> factors;\n    for (int i = 2; i * i <= n; i++) {\n        while (n % i == 0) {\n            n /= i;\n            factors[i]++;\n        }\n    }\n    if (n > 1) factors[n]++;\n    return factors;\n}\nbool is_perfect_square(int n) {\n    auto factors = prime_factors(n);\n    for (auto& f : factors) {\n        if (f.second % 2 != 0) return false;\n    }\n    return true;\n}\nint main() {\n    int n;\n    cin >> n;\n    vector<int> arr(n);\n    for (int& a : arr) cin >> a;\n    int max_length = 0;\n    for (int i = 0; i < n; i++) {\n        map<int, int> odd_count;\n        for (int j = i; j < n; j++) {\n            auto factors = prime_factors(arr[j]);\n            for (auto& f : factors) {\n                if (f.second % 2 != 0) odd_count[f.first]++;\n            }\n            bool ok = true;\n            for (auto& o : odd_count) {\n                if (o.second > 1) ok = false;\n            }\n            if (ok) max_length = max(max_length, j - i + 1);\n        }\n    }\n    cout << max_length << endl;\n}"
  },
