    "cpp": "#include <bits/stdc++.h>\nusing namespace std;\nclass Node {\npublic:\n    int val;\n    Node* next;\n    Node(int x) : val(x), next(NULL) {}\n};\nint lengthOfCycle(Node* head, int cycleIndex) {\n    // TODO\n    return 0;\n}\nint main() {\n    ios_base::sync_with_stdio(false);\n    cin.tie(NULL);\n    int n;\n    cin >> n;\n    vector<int> arr(n);\n    for (int i = 0; i < n; i++) {\n        cin >> arr[i];\n    }\n    int cycleIndex;\n    cin >> cycleIndex;\n    Node* head = new Node(arr[0]);\n    Node* temp = head;\n    for (int i = 1; i < n; i++) {\n        temp->next = new Node(arr[i]);\n        temp = temp->next;\n    }\n    if (cycleIndex != -1) {\n        temp->next = head;\n    }\n    cout << lengthOfCycle(head, cycleIndex) << endl;\n    return 0;\n}",
