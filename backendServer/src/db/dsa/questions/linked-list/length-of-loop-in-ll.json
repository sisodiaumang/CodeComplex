  "solutions": {
    "python": "\nimport sys\nit = iter(sys.stdin.read().split())\nn = int(next(it))\nnodeValues = [int(next(it)) for _ in range(n)]\ncycleIndex = int(next(it))\n\nclass Node:\n    def __init__(self, val):\n        self.val = val\n        self.next = None\n\nhead = Node(nodeValues[0])\ncurrent = head\nfor i in range(1, n):\n    current.next = Node(nodeValues[i])\n    current = current.next\n\nif cycleIndex != -1:\n    current.next = head\n    cycleStart = head\n    for _ in range(cycleIndex):\n        cycleStart = cycleStart.next\n    current = cycleStart\n\nslow = head\nfast = head\nwhile fast and fast.next:\n    slow = slow.next\n    fast = fast.next.next\n    if slow == fast:\n        break\n\nif not fast or not fast.next:\n    print(0)\nelse:\n    slow = head\n    while slow != fast:\n        slow = slow.next\n        fast = fast.next\n    length = 1\n    fast = slow.next\n    while fast != slow:\n        length += 1\n        fast = fast.next\n    print(length)\n",
    "cpp": "\n#include <bits/stdc++.h>\nusing namespace std;\nint main(){\n    int n;\n    if(!(cin >> n)) return 0;\n    vector<int> nodeValues(n);\n    for(int i = 0; i < n; i++) cin >> nodeValues[i];\n    int cycleIndex; cin >> cycleIndex;\n\n    struct Node {\n        int val;\n        Node* next;\n        Node(int val) : val(val), next(nullptr) {}\n    };\n\n    Node* head = new Node(nodeValues[0]);\n    Node* current = head;\n    for(int i = 1; i < n; i++) {\n        current->next = new Node(nodeValues[i]);\n        current = current->next;\n    }\n\n    if(cycleIndex != -1) {\n        current->next = head;\n        Node* cycleStart = head;\n        for(int i = 0; i < cycleIndex; i++) {\n            cycleStart = cycleStart->next;\n        }\n        current = cycleStart;\n    }\n\n    Node* slow = head;\n    Node* fast = head;\n    while(fast && fast->next) {\n        slow = slow->next;\n        fast = fast->next->next;\n        if(slow == fast) break;\n    }\n\n    if(!fast || !fast->next) {\n        cout << 0 << endl;\n    } else {\n        slow = head;\n        while(slow != fast) {\n            slow = slow->next;\n            fast = fast->next;\n        }\n        int length = 1;\n        fast = slow->next;\n        while(fast != slow) {\n            length++;\n            fast = fast->next;\n        }\n        cout << length << endl;\n    }\n    return 0;\n}\n"
  },
