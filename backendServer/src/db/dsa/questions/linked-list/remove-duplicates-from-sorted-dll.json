    "python": "import sys\nit = iter(sys.stdin.read().split())\nn = int(next(it))\nnums = [int(next(it)) for _ in range(n)]\nhead = None\nprev = None\nfor num in nums:\n    if head is None or num != prev.data:\n        node = type('Node', (), {'data': num, 'next': None, 'prev': None})\n        if head is None:\n            head = node\n        else:\n            node.prev = prev\n            prev.next = node\n        prev = node\nresult = []\nwhile head:\n    result.append(str(head.data))\n    head = head.next\nprint(' '.join(result))",
    "cpp": "#include <bits/stdc++.h>\nusing namespace std;\nstruct Node {\n    int data;\n    Node* next;\n    Node* prev;\n    Node(int data) : data(data), next(nullptr), prev(nullptr) {}\n};\nint main() {\n    int n;\n    cin >> n;\n    int* nums = new int[n];\n    for (int i = 0; i < n; i++) cin >> nums[i];\n    Node* head = nullptr;\n    Node* prev = nullptr;\n    for (int i = 0; i < n; i++) {\n        if (head == nullptr || nums[i] != prev->data) {\n            Node* node = new Node(nums[i]);\n            if (head == nullptr) {\n                head = node;\n            } else {\n                node->prev = prev;\n                prev->next = node;\n            }\n            prev = node;\n        }\n    }\n    vector<int> result;\n    while (head) {\n        result.push_back(head->data);\n        head = head->next;\n    }\n    for (int num : result) {\n        cout << num << ' ';\n    }\n    return 0;\n}"
