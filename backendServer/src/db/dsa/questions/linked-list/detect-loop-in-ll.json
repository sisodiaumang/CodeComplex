    "cpp": "#include <bits/stdc++.h>\nusing namespace std;\nint main(){\n    int n;\n    cin >> n;\n    vector<int> vals(n);\n    for(int i = 0; i < n; i++) cin >> vals[i];\n    vector<int> nexts(n);\n    for(int i = 0; i < n; i++) cin >> nexts[i];\n    unordered_set<int> visited;\n    for(int i = 0; i < n; i++){\n        if(nexts[i] == -1) continue;\n        if(visited.find(nexts[i]) != visited.end()){\n            cout << \"true\" << endl;\n            return 0;\n        }\n        visited.insert(nexts[i]);\n    }\n    cout << \"false\" << endl;\n    return 0;\n}"
