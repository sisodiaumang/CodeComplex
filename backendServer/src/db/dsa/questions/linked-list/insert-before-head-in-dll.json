  "starterCode": {
    "cpp": "#include <iostream>\n#include <vector>\nusing namespace std;\n\nstruct Node {\n    int data;\n    Node* next;\n    Node* prev;\n};\n\nclass DoublyLinkedList {\npublic:\n    Node* head;\n    DoublyLinkedList() : head(nullptr) {}\n    void push_back(int new_data) {\n        Node* new_node = new Node();\n        new_node->data = new_data;\n        new_node->next = nullptr;\n        if (head == nullptr) {\n            head = new_node;\n            new_node->prev = nullptr;\n            return;\n        }\n        Node* last = head;\n        while (last->next) {\n            last = last->next;\n        }\n        last->next = new_node;\n        new_node->prev = last;\n    }\n    void printList() {\n        Node* temp = head;\n        vector<int> values;\n        while (temp) {\n            values.push_back(temp->data);\n            temp = temp->next;\n        }\n        cout << values.size() << endl;\n        for (int value : values) {\n            cout << value << endl;\n        }\n    }\n};\n\n// TODO\nint main() {\n    ios_base::sync_with_stdio(false);\n    cin.tie(NULL);\n    int n;\n    cin >> n;\n    DoublyLinkedList dll;\n    int val;\n    for (int i = 0; i < n; i++) {\n        cin >> val;\n        dll.push_back(val);\n    }\n    int new_val;\n    cin >> new_val;\n    // Your code here\n    dll.printList();\n    return 0;\n}",
    "java": "import java.util.Scanner;\nimport java.util.Vector;\n\nclass Node {\n    int data;\n    Node next;\n    Node prev;\n    public Node(int data) {\n        this.data = data;\n        this.next = null;\n        this.prev = null;\n    }\n}\n\nclass DoublyLinkedList {\n    Node head;\n    public void push_back(int new_data) {\n        Node new_node = new Node(new_data);\n        if (head == null) {\n            head = new_node;\n            return;\n        }\n        Node last = head;\n        while (last.next != null) {\n            last = last.next;\n        }\n        last.next = new_node;\n        new_node.prev = last;\n    }\n    public void printList() {\n        Node temp = head;\n        Vector<Integer> values = new Vector<>();\n        while (temp != null) {\n            values.add(temp.data);\n            temp = temp.next;\n        }\n        System.out.println(values.size());\n        for (int value : values) {\n            System.out.println(value);\n        }\n    }\n}\n\npublic class Main {\n    public static void main(String[] args) {\n        Scanner scanner = new Scanner(System.in);\n        int n = scanner.nextInt();\n        DoublyLinkedList dll = new DoublyLinkedList();\n        for (int i = 0; i < n; i++) {\n            int val = scanner.nextInt();\n            dll.push_back(val);\n        }\n        int new_val = scanner.nextInt();\n        // TODO\n        dll.printList();\n    }\n}",
    "python": "class Node:\n    def __init__(self, data=None):\n        self.data = data\n        self.next = None\n        self.prev = None\n\nclass DoublyLinkedList:\n    def __init__(self):\n        self.head = None\n\n    def push_back(self, new_data):\n        new_node = Node(new_data)\n        if not self.head:\n            self.head = new_node\n            return\n        last = self.head\n        while last.next:\n            last = last.next\n        last.next = new_node\n        new_node.prev = last\n\n    def printList(self):\n        temp = self.head\n        values = []\n        while temp:\n            values.append(temp.data)\n            temp = temp.next\n        print(len(values))\n        for value in values:\n            print(value)\n\n# TODO\nif __name__ == '__main__':\n    n = int(input())\n    dll = DoublyLinkedList()\n    for _ in range(n):\n        val = int(input())\n        dll.push_back(val)\n    new_val = int(input())\n    dll.printList()",
    "javascript": "class Node {\n    constructor(data) {\n        this.data = data;\n        this.next = null;\n        this.prev = null;\n    }\n}\n\nclass DoublyLinkedList {\n    constructor() {\n        this.head = null;\n    }\n\n    push_back(new_data) {\n        let new_node = new Node(new_data);\n        if (this.head === null) {\n            this.head = new_node;\n            return;\n        }\n        let last = this.head;\n        while (last.next !== null) {\n            last = last.next;\n        }\n        last.next = new_node;\n        new_node.prev = last;\n    }\n\n    printList() {\n        let temp = this.head;\n        let values = [];\n        while (temp !== null) {\n            values.push(temp.data);\n            temp = temp.next;\n        }\n        console.log(values.length);\n        values.forEach(value => console.log(value));\n    }\n}\n\n// TODO\nlet readline = require('readline');\nlet rl = readline.createInterface({\n    input: process.stdin,\n    output: process.stdout\n});\nlet n;\nlet dll = new DoublyLinkedList();\nlet i = 0;\nlet new_val;\nrl.on('line', line => {\n    if (i === 0) {\n        n = parseInt(line);\n    } else if (i <= n) {\n        dll.push_back(parseInt(line));\n    } else {\n        new_val = parseInt(line);\n        // Your code here\n        dll.printList();\n        rl.close();\n    }\n    i++;\n});"
